# Filo-ERP Environment Variables
# Bu dosyayı kopyalayıp .env.local olarak kaydedin ve kendi değerlerinizi girin
# Bu dosya git'te takip edilir (güvenli şablon)
# .env.local git'te takip EDİLMEZ (gitignore'da)

VITE_SUPABASE_URL=your_supabase_project_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Vercel Dashboard'da bu değerleri Environment Variables olarak ekleyin:
# Settings -> Environment Variables -> Add New
